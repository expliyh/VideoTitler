{
  "name": "@videotitler/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "ensure:electron": "node ./scripts/ensure-electron.mjs",
    "predev": "node ./scripts/ensure-electron.mjs && node ./scripts/ensure-desktop-tooling.mjs",
    "dev": "pnpm exec electron-vite dev",
    "build": "pnpm exec electron-vite build",
    "predist": "node ./scripts/ensure-electron.mjs",
    "dist": "pnpm exec electron-builder --publish never",
    "typecheck": "tsc --noEmit",
    "prebuild": "node ./scripts/ensure-desktop-tooling.mjs"
  },
  "dependencies": {
    "@videotitler/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.videotitler.desktop",
    "productName": "VideoTitler",
    "files": [
      "dist/**"
    ],
    "directories": {
      "output": "release"
    },
    "executableName": "VideoTitler",
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "description": "VideoTitler desktop app",
  "author": "VideoTitler"
}
